generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String    @id @default(uuid())
  slug         String    @unique
  name         String
  plan         String    @default("starter")
  status       String    @default("active")
  address      String
  postalCode   String    @map("postal_code")
  city         String
  country      String
  phone        String
  email        String
  logoFileId   String?   @map("logo_file_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  version      Int       @default(1)
  syncStatus   String    @default("synced") @map("sync_status")
  lastSyncedAt DateTime? @map("last_synced_at")

  users                   User[]
  pushDeviceTokens        PushDeviceToken[]
  customers               Customer[]
  objects                 CustomerObject[]
  installations           Installation[]
  workOrders              WorkOrder[]
  workOrderInstallations  WorkOrderInstallation[]
  checklistTemplates      ChecklistTemplate[]
  checklistTemplateItems  ChecklistTemplateItem[]
  checklistAnswers        ChecklistAnswer[]
  measurements            Measurement[]
  defects                 Defect[]
  photos                  Photo[]
  timeEntries             TimeEntry[]
  materials               Material[]
  workOrderMaterials      WorkOrderMaterial[]
  tariffCatalogItems      TariffCatalogItem[]
  objectTariffAssignments ObjectTariffAssignment[]
  workOrderServiceLines   WorkOrderServiceLine[]
  reportTemplates         ReportTemplate[]
  reports                 Report[]
  fileUploads             FileUpload[]
  syncOutboxEntries       SyncOutboxEntry[]
  auditLogs               AuditLog[]
  legacyImportBatches     LegacyImportBatch[]
  legacyImportRecords     LegacyImportRecord[]

  @@map("tenants")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  email        String
  phone        String?
  role         String
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  version      Int       @default(1)
  syncStatus   String    @default("synced") @map("sync_status")
  lastSyncedAt DateTime? @map("last_synced_at")
  sourceSystem String?   @map("source_system")
  sourceFile   String?   @map("source_file")
  sourceTable  String?   @map("source_table")
  sourceKey    String?   @map("source_key")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  pushDeviceTokens PushDeviceToken[]

  @@unique([tenantId, email])
  @@unique([tenantId, sourceSystem, sourceKey], map: "users_tenant_source_key")
  @@index([tenantId, updatedAt])
  @@map("users")
}

model PushDeviceToken {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  userId     String    @map("user_id")
  token      String
  platform   String
  deviceId   String?   @map("device_id")
  appVersion String?   @map("app_version")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, token], map: "push_tokens_tenant_token_key")
  @@index([tenantId, userId, revokedAt], map: "push_tokens_tenant_user_active_idx")
  @@map("push_device_tokens")
}

model Customer {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  type           String
  displayName    String    @map("display_name")
  firstName      String?   @map("first_name")
  lastName       String?   @map("last_name")
  companyName    String?   @map("company_name")
  email          String?
  phone          String?
  mobile         String?
  billingAddress String?   @map("billing_address")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  version        Int       @default(1)
  syncStatus     String    @default("synced") @map("sync_status")
  lastSyncedAt   DateTime? @map("last_synced_at")
  sourceSystem   String?   @map("source_system")
  sourceFile     String?   @map("source_file")
  sourceTable    String?   @map("source_table")
  sourceKey      String?   @map("source_key")

  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  objects    CustomerObject[]
  workOrders WorkOrder[]

  @@unique([tenantId, sourceSystem, sourceKey], map: "customers_tenant_source_key")
  @@index([tenantId, updatedAt])
  @@map("customers")
}

model CustomerObject {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  customerId   String    @map("customer_id")
  name         String
  street       String
  houseNumber  String    @map("house_number")
  postalCode   String    @map("postal_code")
  city         String
  country      String
  latitude     Float?
  longitude    Float?
  accessNotes  String?   @map("access_notes")
  safetyNotes  String?   @map("safety_notes")
  objectNotes  String?   @map("object_notes")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  version      Int       @default(1)
  syncStatus   String    @default("synced") @map("sync_status")
  lastSyncedAt DateTime? @map("last_synced_at")
  sourceSystem String?   @map("source_system")
  sourceFile   String?   @map("source_file")
  sourceTable  String?   @map("source_table")
  sourceKey    String?   @map("source_key")

  tenant            Tenant                   @relation(fields: [tenantId], references: [id])
  customer          Customer                 @relation(fields: [customerId], references: [id])
  installations     Installation[]
  workOrders        WorkOrder[]
  photos            Photo[]
  tariffAssignments ObjectTariffAssignment[]

  @@unique([tenantId, sourceSystem, sourceKey], map: "objects_tenant_source_key")
  @@index([tenantId, updatedAt])
  @@map("objects")
}

model Installation {
  id                  String    @id @default(uuid())
  tenantId            String    @map("tenant_id")
  objectId            String    @map("object_id")
  type                String
  manufacturer        String?
  model               String?
  serialNumber        String?   @map("serial_number")
  fuelType            String?   @map("fuel_type")
  installationYear    Int?      @map("installation_year")
  locationDescription String?   @map("location_description")
  intervalMonths      Int?      @map("interval_months")
  lastServiceDate     DateTime? @map("last_service_date")
  nextServiceDate     DateTime? @map("next_service_date")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  version             Int       @default(1)
  syncStatus          String    @default("synced") @map("sync_status")
  lastSyncedAt        DateTime? @map("last_synced_at")
  sourceSystem        String?   @map("source_system")
  sourceFile          String?   @map("source_file")
  sourceTable         String?   @map("source_table")
  sourceKey           String?   @map("source_key")

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  object                 CustomerObject          @relation(fields: [objectId], references: [id])
  workOrderInstallations WorkOrderInstallation[]
  measurements           Measurement[]
  defects                Defect[]
  photos                 Photo[]
  serviceLines           WorkOrderServiceLine[]

  @@unique([tenantId, sourceSystem, sourceKey], map: "installations_tenant_source_key")
  @@index([tenantId, updatedAt])
  @@map("installations")
}

model WorkOrder {
  id                      String    @id @default(uuid())
  tenantId                String    @map("tenant_id")
  customerId              String    @map("customer_id")
  objectId                String    @map("object_id")
  assignedUserId          String?   @map("assigned_user_id")
  orderNumber             String    @map("order_number")
  title                   String
  description             String?
  type                    String
  status                  String
  priority                String
  scheduledStart          DateTime? @map("scheduled_start")
  scheduledEnd            DateTime? @map("scheduled_end")
  actualStart             DateTime? @map("actual_start")
  actualEnd               DateTime? @map("actual_end")
  customerSignatureFileId String?   @map("customer_signature_file_id")
  reportFileId            String?   @map("report_file_id")
  completionNotes         String?   @map("completion_notes")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")
  version                 Int       @default(1)
  syncStatus              String    @default("synced") @map("sync_status")
  lastSyncedAt            DateTime? @map("last_synced_at")

  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  customer      Customer                @relation(fields: [customerId], references: [id])
  object        CustomerObject          @relation(fields: [objectId], references: [id])
  installations WorkOrderInstallation[]
  checklist     ChecklistAnswer[]
  measurements  Measurement[]
  defects       Defect[]
  photos        Photo[]
  timeEntries   TimeEntry[]
  materials     WorkOrderMaterial[]
  serviceLines  WorkOrderServiceLine[]
  reports       Report[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, updatedAt])
  @@map("work_orders")
}

model WorkOrderInstallation {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  workOrderId    String    @map("work_order_id")
  installationId String    @map("installation_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  version        Int       @default(1)
  syncStatus     String    @default("synced") @map("sync_status")
  lastSyncedAt   DateTime? @map("last_synced_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  workOrder    WorkOrder    @relation(fields: [workOrderId], references: [id])
  installation Installation @relation(fields: [installationId], references: [id])

  @@unique([tenantId, workOrderId, installationId])
  @@index([tenantId, updatedAt])
  @@map("work_order_installations")
}

model ChecklistTemplate {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  name          String
  type          String
  versionNumber Int       @map("version_number")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  version       Int       @default(1)
  syncStatus    String    @default("synced") @map("sync_status")
  lastSyncedAt  DateTime? @map("last_synced_at")

  tenant Tenant                  @relation(fields: [tenantId], references: [id])
  items  ChecklistTemplateItem[]

  @@index([tenantId, updatedAt])
  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  templateId   String    @map("template_id")
  position     Int
  label        String
  helpText     String?   @map("help_text")
  answerType   String    @map("answer_type")
  required     Boolean   @default(false)
  optionsJson  String?   @map("options_json")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  version      Int       @default(1)
  syncStatus   String    @default("synced") @map("sync_status")
  lastSyncedAt DateTime? @map("last_synced_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  template ChecklistTemplate @relation(fields: [templateId], references: [id])
  answers  ChecklistAnswer[]

  @@index([tenantId, updatedAt])
  @@map("checklist_template_items")
}

model ChecklistAnswer {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  workOrderId    String    @map("work_order_id")
  templateItemId String    @map("template_item_id")
  answerValue    String?   @map("answer_value")
  comment        String?
  isOk           Boolean?  @map("is_ok")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  version        Int       @default(1)
  syncStatus     String    @default("synced") @map("sync_status")
  lastSyncedAt   DateTime? @map("last_synced_at")

  tenant       Tenant                @relation(fields: [tenantId], references: [id])
  workOrder    WorkOrder             @relation(fields: [workOrderId], references: [id])
  templateItem ChecklistTemplateItem @relation(fields: [templateItemId], references: [id])

  @@index([tenantId, updatedAt])
  @@map("checklist_answers")
}

model Measurement {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  workOrderId     String    @map("work_order_id")
  installationId  String?   @map("installation_id")
  measurementType String    @map("measurement_type")
  value           Float
  unit            String
  measuredAt      DateTime  @map("measured_at")
  deviceName      String?   @map("device_name")
  deviceSerial    String?   @map("device_serial")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  version         Int       @default(1)
  syncStatus      String    @default("synced") @map("sync_status")
  lastSyncedAt    DateTime? @map("last_synced_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  workOrder    WorkOrder     @relation(fields: [workOrderId], references: [id])
  installation Installation? @relation(fields: [installationId], references: [id])

  @@index([tenantId, updatedAt])
  @@map("measurements")
}

model Defect {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  workOrderId       String    @map("work_order_id")
  installationId    String?   @map("installation_id")
  severity          String
  title             String
  description       String
  recommendedAction String?   @map("recommended_action")
  dueDate           DateTime? @map("due_date")
  resolved          Boolean   @default(false)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  version           Int       @default(1)
  syncStatus        String    @default("synced") @map("sync_status")
  lastSyncedAt      DateTime? @map("last_synced_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  workOrder    WorkOrder     @relation(fields: [workOrderId], references: [id])
  installation Installation? @relation(fields: [installationId], references: [id])
  photos       Photo[]

  @@index([tenantId, updatedAt])
  @@map("defects")
}

model Photo {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  workOrderId    String?   @map("work_order_id")
  objectId       String?   @map("object_id")
  installationId String?   @map("installation_id")
  defectId       String?   @map("defect_id")
  localPath      String    @map("local_path")
  remoteUrl      String?   @map("remote_url")
  fileName       String    @map("file_name")
  mimeType       String    @map("mime_type")
  sizeBytes      Int       @map("size_bytes")
  caption        String?
  takenAt        DateTime  @map("taken_at")
  uploadStatus   String    @default("pending") @map("upload_status")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  version        Int       @default(1)
  syncStatus     String    @default("synced") @map("sync_status")
  lastSyncedAt   DateTime? @map("last_synced_at")

  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  workOrder    WorkOrder?      @relation(fields: [workOrderId], references: [id])
  object       CustomerObject? @relation(fields: [objectId], references: [id])
  installation Installation?   @relation(fields: [installationId], references: [id])
  defect       Defect?         @relation(fields: [defectId], references: [id])

  @@index([tenantId, updatedAt])
  @@map("photos")
}

model TimeEntry {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  workOrderId     String    @map("work_order_id")
  userId          String    @map("user_id")
  type            String
  startTime       DateTime  @map("start_time")
  endTime         DateTime? @map("end_time")
  durationMinutes Int?      @map("duration_minutes")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  version         Int       @default(1)
  syncStatus      String    @default("synced") @map("sync_status")
  lastSyncedAt    DateTime? @map("last_synced_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@index([tenantId, updatedAt])
  @@map("time_entries")
}

model Material {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  sku              String?
  name             String
  unit             String
  defaultPrice     Float?    @map("default_price")
  stockQuantity    Float?    @map("stock_quantity")
  minStockQuantity Float?    @map("min_stock_quantity")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  version          Int       @default(1)
  syncStatus       String    @default("synced") @map("sync_status")
  lastSyncedAt     DateTime? @map("last_synced_at")

  tenant Tenant              @relation(fields: [tenantId], references: [id])
  usages WorkOrderMaterial[]

  @@index([tenantId, updatedAt])
  @@map("materials")
}

model WorkOrderMaterial {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  workOrderId  String    @map("work_order_id")
  materialId   String?   @map("material_id")
  name         String
  quantity     Float
  unit         String
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  version      Int       @default(1)
  syncStatus   String    @default("synced") @map("sync_status")
  lastSyncedAt DateTime? @map("last_synced_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  material  Material? @relation(fields: [materialId], references: [id])

  @@index([tenantId, updatedAt])
  @@map("work_order_materials")
}

model TariffCatalogItem {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  tariffSystem String    @map("tariff_system")
  code         String
  description  String
  defaultPrice Float?    @map("default_price")
  taxCategory  String?   @map("tax_category")
  taxPoints    Float?    @map("tax_points")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  version      Int       @default(1)
  syncStatus   String    @default("synced") @map("sync_status")
  lastSyncedAt DateTime? @map("last_synced_at")
  sourceSystem String?   @map("source_system")
  sourceFile   String?   @map("source_file")
  sourceTable  String?   @map("source_table")
  sourceKey    String?   @map("source_key")

  tenant            Tenant                   @relation(fields: [tenantId], references: [id])
  objectAssignments ObjectTariffAssignment[]
  serviceLines      WorkOrderServiceLine[]

  @@unique([tenantId, sourceSystem, sourceKey], map: "tariff_catalog_tenant_source_key")
  @@index([tenantId, tariffSystem, code], map: "tariff_catalog_tenant_system_code_idx")
  @@index([tenantId, updatedAt])
  @@map("tariff_catalog_items")
}

model ObjectTariffAssignment {
  id                  String    @id @default(uuid())
  tenantId            String    @map("tenant_id")
  objectId            String?   @map("object_id")
  tariffCatalogItemId String?   @map("tariff_catalog_item_id")
  tariffSystem        String    @map("tariff_system")
  code                String?
  description         String
  position            Int?
  defaultQuantity     Float?    @map("default_quantity")
  unit                String?
  priceOverride       Float?    @map("price_override")
  taxPoints           Float?    @map("tax_points")
  billingCode         String?   @map("billing_code")
  intervalCode        String?   @map("interval_code")
  flag13              String?   @map("flag_13")
  flag14              String?   @map("flag_14")
  flag15              String?   @map("flag_15")
  notes               String?
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  version             Int       @default(1)
  syncStatus          String    @default("synced") @map("sync_status")
  lastSyncedAt        DateTime? @map("last_synced_at")
  sourceSystem        String?   @map("source_system")
  sourceFile          String?   @map("source_file")
  sourceTable         String?   @map("source_table")
  sourceKey           String?   @map("source_key")

  tenant            Tenant                 @relation(fields: [tenantId], references: [id])
  object            CustomerObject?        @relation(fields: [objectId], references: [id])
  tariffCatalogItem TariffCatalogItem?     @relation(fields: [tariffCatalogItemId], references: [id])
  serviceLines      WorkOrderServiceLine[]

  @@unique([tenantId, sourceSystem, sourceKey], map: "object_tariffs_tenant_source_key")
  @@index([tenantId, objectId], map: "object_tariffs_tenant_object_idx")
  @@index([tenantId, tariffSystem, code], map: "object_tariffs_tenant_system_code_idx")
  @@index([tenantId, updatedAt])
  @@map("object_tariff_assignments")
}

model WorkOrderServiceLine {
  id                       String    @id @default(uuid())
  tenantId                 String    @map("tenant_id")
  workOrderId              String    @map("work_order_id")
  objectTariffAssignmentId String?   @map("object_tariff_assignment_id")
  tariffCatalogItemId      String?   @map("tariff_catalog_item_id")
  installationId           String?   @map("installation_id")
  code                     String?
  name                     String
  quantity                 Float
  unit                     String
  unitPrice                Float?    @map("unit_price")
  totalPrice               Float?    @map("total_price")
  taxPoints                Float?    @map("tax_points")
  status                   String    @default("performed")
  notes                    String?
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  deletedAt                DateTime? @map("deleted_at")
  version                  Int       @default(1)
  syncStatus               String    @default("synced") @map("sync_status")
  lastSyncedAt             DateTime? @map("last_synced_at")

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  workOrder              WorkOrder               @relation(fields: [workOrderId], references: [id])
  objectTariffAssignment ObjectTariffAssignment? @relation(fields: [objectTariffAssignmentId], references: [id])
  tariffCatalogItem      TariffCatalogItem?      @relation(fields: [tariffCatalogItemId], references: [id])
  installation           Installation?           @relation(fields: [installationId], references: [id])

  @@index([tenantId, workOrderId], map: "work_order_service_lines_tenant_order_idx")
  @@index([tenantId, updatedAt])
  @@map("work_order_service_lines")
}

model Report {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  workOrderId        String    @map("work_order_id")
  reportNumber       String    @map("report_number")
  status             String
  pdfLocalPath       String?   @map("pdf_local_path")
  pdfRemoteUrl       String?   @map("pdf_remote_url")
  generatedAt        DateTime? @map("generated_at")
  signedAt           DateTime? @map("signed_at")
  customerNameSigned String?   @map("customer_name_signed")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  version            Int       @default(1)
  syncStatus         String    @default("synced") @map("sync_status")
  lastSyncedAt       DateTime? @map("last_synced_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])

  @@unique([tenantId, reportNumber])
  @@index([tenantId, updatedAt])
  @@map("reports")
}

model ReportTemplate {
  id                   String    @id @default(uuid())
  tenantId             String    @map("tenant_id")
  name                 String
  reportType           String    @default("work_order") @map("report_type")
  titlePrefix          String    @default("Rapport") @map("title_prefix")
  locale               String    @default("de")
  primaryColor         String    @default("#1f2937") @map("primary_color")
  footerText           String?   @map("footer_text")
  includeCustomer      Boolean   @default(true) @map("include_customer")
  includeInstallations Boolean   @default(true) @map("include_installations")
  includeMeasurements  Boolean   @default(true) @map("include_measurements")
  includeDefects       Boolean   @default(true) @map("include_defects")
  includeMaterials     Boolean   @default(true) @map("include_materials")
  includeTimeEntries   Boolean   @default(true) @map("include_time_entries")
  includePhotos        Boolean   @default(true) @map("include_photos")
  includeSignature     Boolean   @default(true) @map("include_signature")
  isDefault            Boolean   @default(false) @map("is_default")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")
  version              Int       @default(1)
  syncStatus           String    @default("synced") @map("sync_status")
  lastSyncedAt         DateTime? @map("last_synced_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name], map: "report_templates_tenant_name_key")
  @@index([tenantId, isDefault], map: "report_templates_tenant_default_idx")
  @@index([tenantId, updatedAt])
  @@map("report_templates")
}

model FileUpload {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  entityType  String    @map("entity_type")
  entityId    String    @map("entity_id")
  fileName    String    @map("file_name")
  mimeType    String    @map("mime_type")
  sizeBytes   Int?      @map("size_bytes")
  storageKey  String    @map("storage_key")
  status      String    @default("pending")
  checksum    String?
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@map("file_uploads")
}

model SyncOutboxEntry {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  outboxId      String   @map("outbox_id")
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  operation     String
  status        String
  serverVersion Int?     @map("server_version")
  reason        String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, outboxId])
  @@index([tenantId, entityType, entityId])
  @@map("sync_outbox_entries")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@map("audit_logs")
}

model LegacyImportBatch {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  sourceSystem  String    @default("genesis") @map("source_system")
  archivePath   String    @map("archive_path")
  archiveSha256 String    @map("archive_sha256")
  status        String
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  counts        Json?
  warnings      Json?
  summary       Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant  Tenant               @relation(fields: [tenantId], references: [id])
  records LegacyImportRecord[]

  @@index([tenantId, createdAt], map: "legacy_batches_tenant_created_idx")
  @@index([archiveSha256], map: "legacy_batches_archive_sha_idx")
  @@map("legacy_import_batches")
}

model LegacyImportRecord {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  batchId          String    @map("batch_id")
  sourceSystem     String    @default("genesis") @map("source_system")
  sourceFile       String    @map("source_file")
  sourceTable      String    @map("source_table")
  sourceKey        String    @map("source_key")
  rowHash          String    @map("row_hash")
  rowIndex         Int?      @map("row_index")
  recordType       String    @default("row") @map("record_type")
  mappedEntityType String?   @map("mapped_entity_type")
  mappedEntityId   String?   @map("mapped_entity_id")
  payload          Json
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  version          Int       @default(1)
  syncStatus       String    @default("synced") @map("sync_status")
  lastSyncedAt     DateTime? @map("last_synced_at")

  tenant Tenant            @relation(fields: [tenantId], references: [id])
  batch  LegacyImportBatch @relation(fields: [batchId], references: [id])

  @@unique([batchId, sourceFile, sourceTable, sourceKey], map: "legacy_records_batch_source_key")
  @@index([tenantId, sourceFile, sourceTable], map: "legacy_records_source_idx")
  @@index([tenantId, mappedEntityType, mappedEntityId], map: "legacy_records_mapped_idx")
  @@index([tenantId, updatedAt], map: "legacy_records_tenant_updated_idx")
  @@map("legacy_import_records")
}
