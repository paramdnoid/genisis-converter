NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kaminfeger
JWT_ISSUER=kaminfeger-local
JWT_ACCESS_SECRET=replace-with-a-local-access-secret
JWT_REFRESH_SECRET=replace-with-a-local-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
UPLOAD_BASE_URL=http://localhost:3000/files/upload
LOCAL_UPLOAD_DIR=./uploads
